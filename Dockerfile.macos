FROM ubuntu:22.04

ARG TARGETARCH

# Install user-defined packages from packages.txt
COPY packages.txt /tmp/packages.txt
RUN apt-get update \
    && grep -v '^\s*#' /tmp/packages.txt | grep -v '^\s*$' \
       | xargs apt-get install -y --no-install-recommends \
    && rm -rf /var/lib/apt/lists/* /tmp/packages.txt

# Install Node.js LTS + npm
RUN curl -fsSL https://deb.nodesource.com/setup_lts.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code (binary)
RUN curl -fsSL https://claude.ai/install.sh | bash
RUN cp /root/.local/share/claude/versions/* /usr/local/bin/claude && chmod 755 /usr/local/bin/claude

# Install Docker CLI (static binary, no daemon)
RUN DOCKER_VERSION="24.0.7" \
    && ARCH=$([ "$TARGETARCH" = "arm64" ] && echo "aarch64" || echo "x86_64") \
    && curl -fsSL "https://download.docker.com/linux/static/stable/${ARCH}/docker-${DOCKER_VERSION}.tgz" \
    | tar xz --strip-components=1 -C /usr/local/bin docker/docker

# Allow non-root users to register themselves in passwd/group at runtime
RUN chmod 666 /etc/passwd /etc/group

# Entrypoint: add current user to passwd/group if missing, then exec
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod 755 /usr/local/bin/entrypoint.sh
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

# parse_git_branch for PS1 prompt
RUN echo 'parse_git_branch() { git branch 2>/dev/null | sed -n "s/^* \(.*\)/ (\1)/p"; }' >> /etc/bash.bashrc
